<!DOCTYPE html>
<html lang="en">
<head><nav class="glass sticky top-0 z-50 px-6 py-4 flex justify-between items-center">
    <div class="flex items-center gap-2">
        <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
            <i class="fas fa-gamepad text-white text-xs"></i>
        </div>
        <span class="text-xl font-extrabold tracking-tight text-white">REDEMPSKHID'S <span class="text-blue-500 font-medium">HUB</span></span>
    </div>
    
    <div class="flex gap-4 items-center relative">
        <div class="hidden lg:flex gap-6 text-sm font-semibold text-gray-300 mr-4">
            <a href="#" class="hover:text-blue-500 transition">Consoles</a>
            <a href="#" class="hover:text-blue-500 transition">Latest</a>
        </div>

        <button onclick="toggleMenu()" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-white/10 transition-all focus:outline-none" id="menuButton">
            <i class="fas fa-ellipsis-v text-gray-300"></i>
        </button>

        <div id="dropdownMenu" class="hidden absolute right-0 top-12 w-56 glass rounded-2xl p-2 shadow-2xl z-[60] border border-white/10">
            <a href="#" class="flex items-center gap-3 p-3 rounded-xl hover:bg-blue-600/20 hover:text-blue-400 transition text-sm">
                <i class="fas fa-user-circle w-5"></i> My Profile
            </a>
            <a href="#" class="flex items-center gap-3 p-3 rounded-xl hover:bg-blue-600/20 hover:text-blue-400 transition text-sm">
                <i class="fas fa-history w-5"></i> Download History
            </a>
            <a href="#" class="flex items-center gap-3 p-3 rounded-xl hover:bg-blue-600/20 hover:text-blue-400 transition text-sm">
                <i class="fas fa-cog w-5"></i> Settings
            </a>
            <hr class="border-white/5 my-2">
            <a href="#" class="flex items-center gap-3 p-3 rounded-xl hover:bg-red-600/20 text-red-400 transition text-sm">
                <i class="fas fa-sign-out-alt w-5"></i> Logout
            </a>
        </div>
    </div>
</nav>

<script>
    // Toggle the Three Dots Menu
    function toggleMenu() {
        const menu = document.getElementById('dropdownMenu');
        menu.classList.toggle('hidden');
    }

    // Close menu when clicking outside
    window.addEventListener('click', function(e) {
        const menu = document.getElementById('dropdownMenu');
        const btn = document.getElementById('menuButton');
        if (!btn.contains(e.target) && !menu.contains(e.target)) {
            menu.classList.add('hidden');
        }
    });

    /* Keep your existing Search and Modal logic below this */
</script>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Redempskhid's Game Hub | Premium ROMs</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #3b82f6;
            --bg-dark: #09090b;
            --card-dark: #18181b;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-dark);
            color: #fafafa;
            overflow-x: hidden;
        }

        /* Animated Background Gradient */
        .hero-glow {
            position: absolute;
            top: -100px;
            left: 50%;
            transform: translateX(-50%);
            width: 100%;
            height: 400px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, rgba(9, 9, 11, 0) 70%);
            z-index: -1;
        }

        /* Glassmorphism Effect */
        .glass {
            background: rgba(24, 24, 27, 0.8);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        /* Game Card Hover Effects */
        .game-card {
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .game-card:hover {
            transform: scale(1.05);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5), 0 10px 10px -5px rgba(59, 130, 246, 0.2);
        }

        .download-btn {
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
            transition: 0.3s;
        }

        .download-btn:hover {
            filter: brightness(1.2);
            box-shadow: 0 0 15px rgba(59, 130, 246, 0.5);
        }

        /* Modal Animation */
        #downloadModal {
            transition: opacity 0.3s ease;
        }
    </style>
</head>
<body class="antialiased">

    <div class="hero-glow"></div>

    <nav class="glass sticky top-0 z-50 px-6 py-4 flex justify-between items-center">
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
                <i class="fas fa-gamepad text-white text-xs"></i>
            </div>
            <span class="text-xl font-extrabold tracking-tight text-white">REDEMPSKHID'S <span class="text-blue-500 font-medium">HUB</span></span>
        </div>
        <div class="flex gap-4 items-center">
            <button class="text-gray-400 hover:text-white"><i class="fas fa-search lg:hidden"></i></button>
            <div class="hidden lg:flex gap-6 text-sm font-semibold text-gray-300">
                <a href="#" class="hover:text-blue-500 transition">Consoles</a>
                <a href="#" class="hover:text-blue-500 transition">Latest</a>
                <a href="#" class="hover:text-blue-500 transition">Request Game</a>
            </div>
            <button class="bg-blue-600/10 text-blue-500 px-4 py-2 rounded-full text-xs font-bold border border-blue-500/20">JOIN DISCORD</button>
        </div>
    </nav>

    <header class="max-w-7xl mx-auto px-6 py-16 text-center lg:text-left flex flex-col lg:flex-row items-center gap-12">
        <div class="lg:w-1/2">
            <span class="text-blue-500 font-bold text-xs tracking-widest uppercase mb-4 block">Official 2026 Archive</span>
            <h1 class="text-5xl lg:text-7xl font-extrabold leading-tight mb-6 text-white">Your Favorite <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-600">Retro Games</span> in One Place.</h1>
            <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
                <div class="relative w-full max-w-md">
                    <input type="text" id="mainSearch" placeholder="Search for PSP, PS2, PS3..." 
                        class="w-full bg-zinc-900 border border-white/5 rounded-2xl py-5 pl-14 pr-6 focus:ring-2 focus:ring-blue-500 outline-none transition-all shadow-2xl">
                    <i class="fas fa-search absolute left-5 top-1/2 -translate-y-1/2 text-gray-500"></i>
                </div>
            </div>
        </div>
        <div class="lg:w-1/2 grid grid-cols-2 gap-4">
            <div class="p-6 glass rounded-3xl text-center">
                <h4 class="text-3xl font-bold text-blue-500">5k+</h4>
                <p class="text-xs text-gray-400 uppercase tracking-tighter">Games Verified</p>
            </div>
            <div class="p-6 glass rounded-3xl text-center">
                <h4 class="text-3xl font-bold text-blue-500">99%</h4>
                <p class="text-xs text-gray-400 uppercase tracking-tighter">Up Time</p>
            </div>
        </div>
    </header>

    <section class="max-w-7xl mx-auto px-6 mb-12">
        <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold flex items-center gap-2">
                <i class="fas fa-fire text-orange-500"></i> Trending Now
            </h2>
            <div class="flex gap-2">
                <button class="px-4 py-1.5 rounded-full bg-blue-600 text-[10px] font-bold">ALL</button>
                <button class="px-4 py-1.5 rounded-full glass text-[10px] font-bold hover:bg-zinc-800">PSP</button>
                <button class="px-4 py-1.5 rounded-full glass text-[10px] font-bold hover:bg-zinc-800">PS3</button>
            </div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6" id="gameGrid">
            
            <div class="game-card group cursor-pointer" onclick="openDownload('God of War: Ghost of Sparta', 'PSP', '1.1GB')">
                <div class="relative aspect-[3/4] rounded-2xl overflow-hidden bg-zinc-800 mb-3">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
                    <span class="absolute top-3 left-3 bg-blue-600 text-[9px] font-black px-2 py-1 rounded">PSP</span>
                    <div class="h-full w-full flex items-center justify-center">
                        <i class="fas fa-compact-disc text-5xl text-zinc-700 group-hover:rotate-180 transition-transform duration-700"></i>
                    </div>
                    <div class="absolute bottom-4 left-4 right-4">
                        <h3 class="game-title text-sm font-bold truncate">God of War: Ghost of Sparta</h3>
                        <p class="text-[10px] text-gray-400 mt-1 uppercase">Action • ISO</p>
                    </div>
                </div>
            </div>

            <div class="game-card group cursor-pointer" onclick="openDownload('Tekken 6', 'PSP', '800MB')">
                <div class="relative aspect-[3/4] rounded-2xl overflow-hidden bg-zinc-800 mb-3">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
                    <span class="absolute top-3 left-3 bg-indigo-600 text-[9px] font-black px-2 py-1 rounded">PSP</span>
                    <div class="h-full w-full flex items-center justify-center">
                        <i class="fas fa-fist-raised text-5xl text-zinc-700 group-hover:scale-110 transition-all"></i>
                    </div>
                    <div class="absolute bottom-4 left-4 right-4">
                        <h3 class="game-title text-sm font-bold truncate">Tekken 6</h3>
                        <p class="text-[10px] text-gray-400 mt-1 uppercase">Fighting • ISO</p>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <div id="downloadModal" class="hidden fixed inset-0 z-[100] flex items-center justify-center px-6">
        <div class="absolute inset-0 bg-black/90 backdrop-blur-sm" onclick="closeModal()"></div>
        <div class="glass max-w-md w-full rounded-3xl p-8 relative z-10 text-center">
            <div id="modalIcon" class="w-20 h-20 bg-blue-600/20 text-blue-500 rounded-full flex items-center justify-center mx-auto mb-6">
                <i class="fas fa-download text-3xl"></i>
            </div>
            <h2 id="modalTitle" class="text-2xl font-bold mb-2 text-white">Game Title</h2>
            <p id="modalInfo" class="text-gray-400 text-sm mb-8 italic">Console | Size</p>
            
            <div class="grid gap-4">
                <button class="download-btn py-4 rounded-2xl font-bold text-white flex items-center justify-center gap-2">
                    <i class="fas fa-cloud-download-alt"></i> SERVER 1 (FAST)
                </button>
                <button class="bg-zinc-800 py-4 rounded-2xl font-bold text-gray-300 hover:bg-zinc-700 transition">
                    SERVER 2 (DIRECT)
                </button>
            </div>
            <button onclick="closeModal()" class="mt-6 text-gray-500 text-xs hover:text-white">CLOSE</button>
        </div>
    </div>

    <footer class="mt-20 border-t border-white/5 py-12 text-center glass">
        <p class="text-sm font-bold text-gray-400">&copy; 2026 <span class="text-blue-500">REDEMPSKHIDSGAMEHUB.COM</span></p>
        <div class="flex justify-center gap-6 mt-4 text-gray-500">
            <a href="#"><i class="fab fa-facebook hover:text-blue-500"></i></a>
            <a href="#"><i class="fab fa-twitter hover:text-blue-500"></i></a>
            <a href="#"><i class="fab fa-github hover:text-white"></i></a>
        </div>
    </footer>

    <script>
        // Search Logic
        const searchInput = document.getElementById('mainSearch');
        const cards = document.querySelectorAll('.game-card');

        searchInput.addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase();
            cards.forEach(card => {
                const title = card.querySelector('.game-title').textContent.toLowerCase();
                card.style.display = title.includes(query) ? 'block' : 'none';
            });
        });

        // Modal Logic
        function openDownload(title, console, size) {
            document.getElementById('modalTitle').innerText = title;
            document.getElementById('modalInfo').innerText = `${console} | ${size} | .ISO`;
            document.getElementById('downloadModal').classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('downloadModal').classList.add('hidden');
        }
    </script>
</body>
</html>

